PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=tx-prediction-backend

# APIs
PREDICTION_API_URL=https://aims-discussions-nottingham-milton.trycloudflare.com/api/txmd5
RESULTS_API_URL=https://wtxmd52.tele68.com/v1/txmd5/sessions

# Polling Config
PREDICTION_POLL_MS=1500
RESULTS_POLL_MS=2000
REQUEST_TIMEOUT_MS=6000

# Database & Storage
DATABASE_PATH=./data/tx-monitor.sqlite
PATTERN_DATA_PATH=./data/cau-patterns.txt
MAX_STORED_SESSIONS=20000
HISTORY_DEFAULT_LIMIT=100
HISTORY_MAX_LIMIT=1000

# Alert Config
ALERT_WINDOW_SIZE=5
ALERT_WIN_RATE_THRESHOLD=80
BETTING_SAMPLE_SIZE=500

# Predictor Config
PREDICTOR_HISTORY_SIZE=400
PREDICTOR_MODEL_EVAL_WINDOW=300

# Betting Advice Config
BET_ADVICE_MIN_CONFIDENCE=57
BET_ADVICE_MIN_WIN_RATE_10=55
BET_ADVICE_MIN_WIN_RATE_30=56
BET_ADVICE_MIN_SIGNAL_SCORE=54
BET_ADVICE_STRONG_SIGNAL_SCORE=72
BET_ADVICE_MIN_ENSEMBLE_ACC=60
BET_ADVICE_MAX_BANKROLL_PERCENT=8
BETTING_UNIT=1000
CALIBRATION_MAP={"50-70":57.26,"70-80":75.29,"90-100":99.17}

# Logging
LOG_LEVEL=info
LOG_REQUESTS=false

# Performance
ENABLE_COMPRESSION=true
CACHE_DURATION_MS=1000
